{
  "name": "@theclearsky/react-blender-nodes",
  "version": "0.0.11",
  "type": "module",
  "author": "Deepak Prasad <TheClearSky@github.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheClearSky/react-blender-nodes.git"
  },
  "homepage": "https://github.com/TheClearSky/react-blender-nodes",
  "keywords": [
    "react",
    "blender",
    "nodes",
    "graph",
    "editor"
  ],
  "description": "A React component library inspired by Blender's node editor interface, providing a flexible and customizable node-based graph editor for web applications.",
  "files": [
    "dist"
  ],
  "main": "./dist/react-blender-nodes.umd.cjs",
  "module": "./dist/react-blender-nodes.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/react-blender-nodes.es.js",
      "require": "./dist/react-blender-nodes.umd.cjs"
    },
    "./style.css": "./dist/react-blender-nodes.css"
  },
  "scripts": {
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "pretty": "prettier --write .",
    "pretty:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "checklist": "npm i && npm run prepare && npm run pretty && npm run build && npm run build-storybook",
    "cl": "npm run checklist",
    "prepare": "husky",
    "find-dead-code": "npx knip",
    "ded": "npm run find-dead-code"
  },
  "peerDependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.16",
    "@fontsource/dejavu-sans": "^5.2.5",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@xyflow/react": "^12.8.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "husky": "^9.1.7",
    "immer": "^11.1.4",
    "lint-staged": "^16.2.6",
    "lucide-react": "^1.14.0",
    "prettier": "^3.6.2",
    "radix-ui": "^1.4.3",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-vitest": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@tailwindcss/vite": "^4.1.13",
    "@types/lodash": "^4.17.20",
    "@types/node": "^25.6.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^10.3.6",
    "globals": "^17.6.0",
    "knip": "^6.0.1",
    "playwright": "^1.55.0",
    "storybook": "^10.3.6",
    "storybook-addon-test-codegen": "^3.0.1",
    "tailwindcss": "^4.1.12",
    "tw-animate-css": "^1.3.8",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.42.0",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*": [
      "npm run pretty"
    ]
  }
}
